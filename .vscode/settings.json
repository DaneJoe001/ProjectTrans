  "commentTranslate.browse.mode": "contrast",
  // 目录排除（监听/搜索/索引）
  "files.exclude": {
    "**/.git": true,
    "**/build": true,
    "**/out": true,
    "**/bin": true,
    "**/obj": true,
    "**/vcpkg_installed": true,
    "**/.cache": true
  },
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/build/**": true,
    "**/out/**": true,
    "**/bin/**": true,
    "**/obj/**": true,
    "**/vcpkg_installed/**": true
  },
  "search.exclude": {
    "**/build": true,
    "**/out": true,
    "**/bin": true,
    "**/obj": true,
    "**/vcpkg_installed": true
  },
  // Git 大仓库优化
  "git.autofetch": false,
  "git.decorations.enabled": false,
  "git.countBadge": "tracked",
  "git.untrackedChanges": "separate",
  // 终端/渲染
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.scrollback": 2000,
  // cpptools 关键项
  "C_Cpp.default.compileCommands": "${workspaceFolder}/compile_commands.json",
  "C_Cpp.default.compilerPath": "C:/Path/To/Your/Compiler/g++.exe",
  "C_Cpp.intelliSenseCachePath": "e:/vscode_cache/intellisense",
  "C_Cpp.intelliSenseCacheSize": 4096,
  "C_Cpp.workspaceParsingPriority": "low",
  "C_Cpp.enhancedColorization": "Disabled",
  "C_Cpp.loggingLevel": "Warning",
  "C_Cpp.codeAnalysis.enabled": false
}